model MoodboardItem {
  id String @id @default(cuid())

  moodboardId String
  moodboard   Moodboard @relation(fields: [moodboardId], references: [id], onDelete: Cascade)

  type     MoodboardItemType
  position Int               @default(0)
  colSpan  Int               @default(1)

  /// Freeform canvas position and size (logical pixels)
  x      Float @default(0)
  y      Float @default(0)
  width  Float @default(280)
  height Float @default(0) /// 0 = auto-height (content determines)

  /// Polymorphic JSON data — shape depends on `type`:
  /// NOTE:  { title?, body }
  /// IMAGE: { url, storageKey, caption?, width?, height?, originalName?, mimeType?, bytes? }
  /// COLOR: { hex, name? }
  /// LINK:  { url, title?, description?, favicon? }
  /// FILE:  { url, storageKey, originalName, mimeType, bytes }
  /// TODO:  { title?, items: [{ id, text, checked }] }
  data Json

  createdById String
  createdBy   UserAccount @relation("MoodboardItemCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([moodboardId, position])
}

// -----------------------------------------------------------------------------
// Consultations
//
// Company OWNER / PM members can request a video consultation with the
// Brandbite admin team. Costs tokens up-front (debited via TokenLedger on
// submit, refunded on admin/company cancel). Status lifecycle:
//   PENDING    — customer submitted, admin hasn't scheduled yet
//   SCHEDULED  — admin picked a time + video link, customer notified
//   COMPLETED  — call happened (manually marked by admin)
//   CANCELED   — either side backed out; refund posted if we had debited
//
// MVP deliberately keeps scheduling out-of-band: the admin pastes a
// Google Meet / Zoom link into `videoLink` when flipping to SCHEDULED.
// A later PR can swap this for a Cal.com-style embed without changing
// the data model.
// -----------------------------------------------------------------------------

enum ConsultationStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELED
}

model Consultation {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  requestedByUserId String
  requestedBy       UserAccount @relation("ConsultationsRequested", fields: [requestedByUserId], references: [id])

  /// What the customer wants to discuss (required).
  description String

  /// Customer-proposed time slots as free-text or ISO strings. Optional.
  /// Persisted as JSON so an upgraded form can switch to structured slots
  /// without a migration.
  preferredTimes Json?

  /// Customer's timezone at submit-time, e.g. "Europe/Istanbul".
  timezone String?

  /// Admin fills these when scheduling.
  scheduledAt DateTime?
  videoLink   String?
  adminNotes  String?

  /// Google Calendar event id if the booking was auto-scheduled by the
  /// Google integration. Null when the booking is in the legacy PENDING
  /// flow (no Google connected at submit time).
  googleEventId String?

  /// Token cost snapshot (in case admin changes pricing later).
  tokenCost Int

  status ConsultationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, createdAt])
  @@index([status, createdAt])
}

// -----------------------------------------------------------------------------
// ConsultationSettings
// -----------------------------------------------------------------------------
// Site-level configuration for the consultation feature. Managed by
// SITE_OWNER / SITE_ADMIN from /admin/consultations/settings.
//
// Enforced as a singleton via `@unique` on `singleton = true` — Postgres will
// reject a second row since `true` is already taken.
// -----------------------------------------------------------------------------

model ConsultationSettings {
  id        String  @id @default(cuid())
  singleton Boolean @unique @default(true)

  /// Master switch — when false, customer form refuses new bookings.
  enabled Boolean @default(true)

  /// Tokens charged on submit. Replaces the old hardcoded CONSULTATION_TOKEN_COST.
  tokenCost Int @default(50)

  /// Duration (minutes) shown to the customer.
  durationMinutes Int @default(30)

  /// Team contact email (Gmail/etc.) — shown to the customer and used as a
  /// notification target by future integrations.
  contactEmail String?

  /// Public "secret iCal URL" of the team's Google Calendar. Parsed
  /// server-side to surface busy windows on the customer picker.
  calendarIcsUrl String?

  /// Days the team is available (0=Sun ... 6=Sat). Defaults to Mon-Fri.
  workingDays Int[] @default([1, 2, 3, 4, 5])

  /// Working hour window in 24h local time (company timezone).
  workingHourStart Int @default(9)
  workingHourEnd   Int @default(17)

  /// Minimum notice (hours) a customer must give when picking a slot.
  minNoticeHours Int @default(24)

  /// Max days in the future a customer may pick.
  maxBookingDays Int @default(30)

  /// Company timezone, IANA zone. Used when interpreting working hours.
  companyTimezone String?

  /// Free-text notes shown only to admins on the settings page.
  adminNotes String?

  /// Google Calendar OAuth state. Populated when SITE_OWNER / SITE_ADMIN
  /// connects the team Gmail via /admin/consultation-settings/google/connect.
  /// Tokens persisted here plaintext for now — rotating encryption key is a
  /// follow-up; low blast radius since the DB is single-tenant and the
  /// refresh token only scopes calendar.events + calendar.freebusy.
  googleAccountEmail   String?
  googleCalendarId     String?   @default("primary")
  googleAccessToken    String?
  googleRefreshToken   String?
  googleTokenExpiresAt DateTime?
  googleConnectedAt    DateTime?

  updatedAt DateTime @updatedAt

  updatedById String?
  updatedBy   UserAccount? @relation("ConsultationSettingsUpdatedBy", fields: [updatedById], references: [id])
}

// -----------------------------------------------------------------------------
// Admin action audit log (Security Precaution Plan — L1)
//
// Write-only ledger of every privileged action. Rows never update; rows
// never delete (even on UserAccount soft-delete — we anonymize references
// in app code rather than FK-cascade). This is forensic infrastructure:
// the first thing we read after a suspected compromise, and the evidence
// trail for any billing dispute or regulatory audit.
//
// The actor snapshot (actorEmail, actorRole) is denormalized on purpose —
// UserAccount email gets anonymized on GDPR delete, and role may change
// after the action. The log must show who did what at the time, not who
// the actor IS today.
// -----------------------------------------------------------------------------

enum AdminActionType {
  // Withdrawals
  WITHDRAWAL_APPROVE
  WITHDRAWAL_MARK_PAID
  WITHDRAWAL_REJECT
  // Plans & billing
  PLAN_CREATE
  PLAN_EDIT
  PLAN_DELETE
  PLAN_ASSIGN
  COMPANY_TOKEN_GRANT
  // Creative payout rules
  PAYOUT_RULE_EDIT
  // Ticket financial overrides
  TICKET_FINANCIAL_OVERRIDE
  // User / role management
  USER_PROMOTE_TO_ADMIN
  USER_HARD_DELETE
  // Pricing / configuration
  AI_PRICING_EDIT
  CONSULTATION_PRICING_EDIT
  GOOGLE_OAUTH_CONFIG_EDIT
}

enum AdminActionOutcome {
  SUCCESS // action completed
  BLOCKED // guard rejected (403, validation, etc.) — valuable for recon detection
  ERROR // downstream failure mid-action (DB, external API)
}

model AdminActionLog {
  id String @id @default(cuid())

  // Who performed the action, snapshotted for forensic stability
  actorId    String
  actor      UserAccount @relation("AdminActionLogActor", fields: [actorId], references: [id])
  actorEmail String // snapshot at action time; UserAccount.email may anonymize later
  actorRole  UserRole // snapshot; role may change after the action

  // What the action is + action-specific payload
  action   AdminActionType
  metadata Json? // e.g. { amountTokens, oldPrice, newPrice, … }

  // Target object, if the action has one. Soft-linked (no FK) because the
  // target table varies by action type (Withdrawal, Plan, UserAccount, …).
  targetType String? // "Withdrawal" | "Plan" | "UserAccount" | "Company" | "Ticket" | …
  targetId   String?

  // Request context — where did this come from?
  ipAddress String?
  userAgent String?

  // Outcome (success / blocked / error)
  outcome      AdminActionOutcome
  errorMessage String? // populated when outcome != SUCCESS

  createdAt DateTime @default(now())

  // Query access patterns:
  //   - "what has this owner done" → actorId + createdAt
  //   - "who touched this withdrawal" → targetType + targetId + createdAt
  //   - "show me every MARK_PAID this week" → action + createdAt
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId, createdAt])
}

// -----------------------------------------------------------------------------
// MFA challenge table (Security Precaution Plan — L4)
//
// Email-code second factor for money-moving admin actions. When a SITE_OWNER
// tries a money action and has no recent successful MFA, the route issues a
// challenge: generates a 6-digit code, stores the SHA-256 of it here, emails
// the plaintext code, and returns 202 to the client. The client prompts for
// the code and POSTs to /api/admin/mfa/verify which sets `consumedAt`.
//
// "Recent MFA" is just a query: did this user consume any challenge of this
// actionTag within the last N minutes? No separate session table needed.
// -----------------------------------------------------------------------------

model MfaChallenge {
  id     String      @id @default(cuid())
  userId String
  user   UserAccount @relation(fields: [userId], references: [id])

  // actionTag scopes the challenge to a category of action. We use a single
  // tag "MONEY_ACTION" for all L2-protected routes — completing MFA once
  // unlocks withdrawals + token grants + role escalations for the window.
  actionTag String

  // SHA-256 of the 6-digit plaintext code. We never store the code itself.
  codeHash String

  // Issued codes expire quickly (10 min) so a stale code can't be replayed
  // hours later. Separate from the "recent successful MFA" window.
  expiresAt DateTime

  // Set when the code is successfully verified. The presence of a
  // consumedAt within the last 30 min is what "recent MFA" means.
  consumedAt DateTime?

  // Count of wrong-code attempts. At 5, the challenge is locked (further
  // attempts rejected with a clear message, user must issue a new code).
  attempts Int @default(0)

  // Request context snapshot for forensic correlation with AdminActionLog.
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  // Query patterns:
  //   - "does this user have a recent consumed challenge?" →
  //     userId + actionTag + consumedAt
  //   - housekeeping "delete expired unconsumed" → expiresAt
  @@index([userId, actionTag, consumedAt])
  @@index([expiresAt])
}
