// -----------------------------------------------------------------------------
// AI Generations
// -----------------------------------------------------------------------------

model AiGeneration {
  id       String     @id @default(cuid())
  toolType AiToolType

  userId String
  user   UserAccount @relation(fields: [userId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  /// Optional ticket context (null for standalone AI Tools usage)
  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id])

  /// The prompt/input sent to the AI provider
  prompt      String
  /// Full parameters sent (model, size, style, etc.)
  inputParams Json?

  /// Provider response details
  provider String // "openai" | "replicate"
  model    String // "dall-e-3", "flux-pro", "gpt-4o", "rmbg-2.0"

  status AiGenerationStatus @default(PENDING)

  /// Client-supplied idempotency key (UUID). A retry of the same submission
  /// with the same key returns the existing generation instead of debiting
  /// tokens again. Unique when present; null for legacy / server-only calls.
  idempotencyKey String? @unique

  /// AI output (text, URLs, suggestions JSON)
  outputText     String?
  outputImageUrl String?
  outputParams   Json?

  /// Cost tracking
  tokenCost    Int   @default(0)
  providerCost Json? // Actual API cost details for internal tracking

  /// Error handling
  errorMessage String?
  retryCount   Int     @default(0)

  /// Timing
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  /// Relations
  revisions TicketRevision[]

  @@index([userId, createdAt])
  @@index([companyId, createdAt])
  @@index([ticketId, createdAt])
  @@index([toolType, status])
}

model AiToolConfig {
  id       String     @id @default(cuid())
  toolType AiToolType @unique

  /// Whether this tool is currently enabled
  enabled Boolean @default(true)

  /// Token cost per operation
  tokenCost Int @default(1)

  /// Rate limiting (max operations per company per hour)
  rateLimit Int @default(20)

  /// Provider config overrides (model version, size defaults, etc.)
  config Json?

  updatedAt DateTime @updatedAt
}

