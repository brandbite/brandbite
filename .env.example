# PostgreSQL (Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/db"

# App URL (used by Stripe, emails, BetterAuth — set to your production domain)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# BetterAuth
BETTER_AUTH_SECRET=""          # generate with: openssl rand -base64 32

# Demo mode (set to "true" for local dev with demo personas, "false" for real auth).
# In production builds (NODE_ENV=production) demo mode is ignored unless
# ALLOW_DEMO_IN_PROD is also set — this prevents accidental exposure of the
# persona switcher in real customer environments.
DEMO_MODE="true"
NEXT_PUBLIC_DEMO_MODE="true"

# Intentional demo deploys (e.g. demo.brandbite.studio) opt back in to demo
# mode in production by setting these. Do NOT set in real customer envs.
# ALLOW_DEMO_IN_PROD=""
# NEXT_PUBLIC_ALLOW_DEMO_IN_PROD=""

# Stripe
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Resend Email
RESEND_API_KEY=""
EMAIL_FROM="BrandBite <notifications@brandbite.studio>"

# Cloudflare R2 (S3-compatible file storage)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="brandbite-assets"
R2_REGION="auto"
R2_ENDPOINT=""
# R2_PUBLIC_BASE_URL=""        # optional: custom domain for public assets

# AI Tools (OpenAI + Replicate)
OPENAI_API_KEY=""                # Required for GPT-4o text gen + DALL-E 3 image gen
# OPENAI_ORG_ID=""              # Optional: OpenAI organization ID
REPLICATE_API_TOKEN=""           # Required for Flux Pro image gen + RMBG background removal

# Sentry
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Upstash Redis (rate limiter — production only).
# When unset, rate limiting falls back to an in-memory Map which does NOT
# work across multiple Vercel serverless instances. Set the URL + TOKEN
# pair using any of these conventions (lib/rate-limit.ts checks all three,
# preferring the first that is set):
#
#   1. UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN — explicit names.
#   2. KV_REST_API_URL / KV_REST_API_TOKEN — Upstash SDK convention.
#   3. UPSTASH_REDIS_REST_KV_REST_API_URL / ..._TOKEN — what Vercel's
#      Upstash marketplace integration auto-injects when you pick the
#      "UPSTASH_REDIS_REST" prefix during setup.
#
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
